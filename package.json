{
    "scripts": {
        "test": "jest",
        "tsc": "tsc --project tsconfig.json",
        "lint": "eslint '**/*.{ts,js}'",
        "lint-fix": "eslint --fix '**/*.{ts,js}'",
        "start": "ts-node -T src/server.ts",
        "cleanup-sync-request": "pkill -f node_modules/sync-rpc/lib/worker.js > /dev/null 2>&1",
        "posttest": "npm run cleanup-sync-request || true",
        "ts-node-coverage": "nyc --reporter=text --reporter=lcov ts-node -T src/server.ts",
        "ts-node-dev": "ts-node-dev -T src/server.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "form-data": "^4.0.2",
        "jssha": "^3.3.1",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "randomstring": "^1.3.1",
        "ts-node": "^10.9.2",
        "uuid": "^11.1.0",
        "validator": "^13.12.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/http-errors": "^2.0.4",
        "@types/jest": "^29.5.12",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^20.14.7",
        "@types/prompt-sync": "^4.2.3",
        "@types/randomstring": "^1.3.0",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^10.0.0",
        "@types/validator": "^13.12.0",
        "@typescript-eslint/eslint-plugin": "^6.20.0",
        "@typescript-eslint/parser": "^6.20.0",
        "eslint": "^8.57.1",
        "eslint-plugin-jest": "^27.6.3",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "swagger-ui-express": "^5.0.1",
        "sync-request-curl": "~3.2.0",
        "ts-jest": "^29.1.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.27.0",
        "yaml": "^2.4.5"
    },
    "nyc": {
        "exclude": [
            "echo.*"
        ]
    }
}
